{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://trello.com"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/connector.html",
      "destination": "/connector.html"
    },
    {
      "source": "/settings.html",
      "destination": "/settings.html"
    },
    {
      "source": "/card-back.html",
      "destination": "/card-back.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
